"""
People's Daily NER 数据集处理模块

数据格式说明：
  - tokens: 已分词的字符列表
  - ner_tags: 对应的 BIO 标签列表
  
标签体系：
  - PER: 人名（如：毛泽东、邓小平）
  - ORG: 组织机构（如：共产党、国务院）
  - LOC: 地点（如：北京、厦门）

使用方式：
  from dataset_peoples_daily import PeoplesDailyDataset, build_peoples_daily_loaders
"""

import json
from pathlib import Path
from typing import Optional

import torch
from torch.utils.data import Dataset, DataLoader
from transformers import BertTokenizer


class PeoplesDailyDataset(Dataset):
    """People's Daily NER 数据集。
    
    教学流程：
      tokens (已分词) → BertTokenizer 编码
      → 用 word_ids() 对齐子词标签（非首子词设为 -100）
      → 返回 input_ids / attention_mask / token_type_ids / labels
    """

    def __init__(
        self,
        records: list,
        tokenizer: BertTokenizer,
        label2id: dict,
        max_length: int = 128,
    ):
        self.records = records
        self.tokenizer = tokenizer
        self.label2id = label2id
        self.max_length = max_length

    def __len__(self):
        return len(self.records)

    def __getitem__(self, idx: int) -> dict:
        row = self.records[idx]
        tokens: list = row["tokens"]
        ner_tags: list = row["ner_tags"]

        # 1. 将字符串标签转换为 ID
        char_labels = [self.label2id.get(tag, 0) for tag in ner_tags]

        # 2. 使用 tokenizer 编码（is_split_into_words=True）
        encoding = self.tokenizer(
            tokens,
            is_split_into_words=True,
            max_length=self.max_length,
            truncation=True,
            padding="max_length",
            return_tensors="pt",
        )

        # 3. 子词对齐：取每个 token 对应的字符索引
        word_ids = encoding.word_ids(batch_index=0)
        aligned_labels = []
        prev_word_id = None
        for wid in word_ids:
            if wid is None:
                aligned_labels.append(-100)
            elif wid != prev_word_id:
                if wid < len(char_labels):
                    aligned_labels.append(char_labels[wid])
                else:
                    aligned_labels.append(-100)
                prev_word_id = wid
            else:
                aligned_labels.append(-100)

        labels_tensor = torch.tensor(aligned_labels, dtype=torch.long)

        return {
            "input_ids": encoding["input_ids"].squeeze(0),
            "attention_mask": encoding["attention_mask"].squeeze(0),
            "token_type_ids": encoding["token_type_ids"].squeeze(0),
            "labels": labels_tensor,
        }


def load_peoples_daily_records(split: str, data_dir: Optional[Path] = None) -> list:
    """加载 People's Daily 数据集的一个划分。
    
    Args:
        split: 数据划分，支持 "train", "validation", "test"
        data_dir: 数据目录路径
    
    Returns:
        记录列表，每条记录包含 tokens 和 ner_tags
    """
    d = data_dir or Path(__file__).parent.parent / "data" / "peoples_daily"
    with open(d / f"{split}.json", "r", encoding="utf-8") as f:
        return json.load(f)


def build_peoples_daily_loaders(
    tokenizer: BertTokenizer,
    label2id: dict,
    batch_size: int = 32,
    max_length: int = 128,
    data_dir: Optional[Path] = None,
) -> tuple[DataLoader, DataLoader, DataLoader]:
    """构建 People's Daily 训练/验证/测试 DataLoader。
    
    Args:
        tokenizer: BERT tokenizer
        label2id: 标签到 ID 的映射
        batch_size: 批次大小
        max_length: 最大序列长度
        data_dir: 数据目录
    
    Returns:
        (train_loader, val_loader, test_loader)
    """
    train_records = load_peoples_daily_records("train", data_dir)
    val_records = load_peoples_daily_records("validation", data_dir)
    test_records = load_peoples_daily_records("test", data_dir)

    train_ds = PeoplesDailyDataset(train_records, tokenizer, label2id, max_length)
    val_ds = PeoplesDailyDataset(val_records, tokenizer, label2id, max_length)
    test_ds = PeoplesDailyDataset(test_records, tokenizer, label2id, max_length)

    print(f"People's Daily 数据集规模：训练={len(train_ds)}，验证={len(val_ds)}，测试={len(test_ds)}")

    train_loader = DataLoader(train_ds, batch_size=batch_size, shuffle=True, num_workers=0)
    val_loader = DataLoader(val_ds, batch_size=batch_size, shuffle=False, num_workers=0)
    test_loader = DataLoader(test_ds, batch_size=batch_size, shuffle=False, num_workers=0)

    return train_loader, val_loader, test_loader
