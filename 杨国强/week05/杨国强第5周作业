"""
字符级语言模型训练脚本，支持 RNN / LSTM / Transformer 三种架构。
包含训练、验证、困惑度计算和文本生成功能。

用法:
    # Transformer (默认)
    python week5homwok.py --epochs 20

    # LSTM
    python week5homwok.py --model lstm --epochs 20

    # RNN
    python week5homwok.py --model rnn --epochs 20

    # 自定义参数
    python week5homwok.py --embed_dim 256 --hidden_dim 512 --num_layers 4 --nhead 8
"""

import math
import argparse
import glob
import random
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader


