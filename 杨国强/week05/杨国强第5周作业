def main():
    """
    主函数：整合数据、模型、训练流程。
    
    完整流程:
        1. 命令行参数解析
        2. 设备选择（GPU/CPU）
        3. 加载语料库
        4. 构建词表
        5. 划分训练集/验证集
        6. 创建模型
        7. 训练循环
        8. 保存最佳模型
    """
    # ── 1. 命令行参数解析 ──
    parser = argparse.ArgumentParser(description="字符级语言模型（RNN/LSTM/Transformer）")
    
    # 模型类型: rnn, lstm 或 transformer
    parser.add_argument("--model",      default="transformer", 
                       choices=["rnn", "lstm", "transformer"])
    # Transformer 注意力头数
    parser.add_argument("--nhead",      type=int,   default=8)
    # 训练轮数
    parser.add_argument("--epochs",     type=int,   default=20)
    # 输入序列长度（每个样本包含的字符数）
    parser.add_argument("--seq_len",    type=int,   default=64)
    # 批大小（每批样本数）
    parser.add_argument("--batch_size", type=int,   default=128)
    # 嵌入维度
    parser.add_argument("--embed_dim",  type=int,   default=128)
    # 隐藏层维度
    parser.add_argument("--hidden_dim", type=int,   default=256)
    # RNN 层数
    parser.add_argument("--num_layers", type=int,   default=2)
    # Dropout 比例
    parser.add_argument("--dropout",    type=float, default=0.3)
    # 学习率
    parser.add_argument("--lr",         type=float, default=1e-3)
    # 验证集比例（例如 0.05 表示 5% 用于验证）
    parser.add_argument("--val_ratio",  type=float, default=0.05)
    # 语料库文件路径
    parser.add_argument("--corpus",     default="*.txt")
    # 模型保存路径
    parser.add_argument("--save",       default="best_model.pt")
    
    args = parser.parse_args()
    
    # ── 2. 设备选择 ──
    # 优先使用 GPU（CUDA），不可用时回退到 CPU
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"device: {device}  model: {args.model.upper()}")
    
    # ── 3. 数据准备 ──
    # 加载语料库（支持通配符，如 "data/*.txt"）
    text = load_corpus(args.corpus)
    if not text:
        raise FileNotFoundError("未找到任何 .txt 文件，请确认路径正确。")
    print(f"语料字符数: {len(text):,}")
    
    # 构建字符到索引的映射
    char2idx, idx2char = build_vocab(text)
    vocab_size = len(char2idx)
    print(f"词表大小: {vocab_size}")
    
    # ── 4. 划分训练集和验证集 ──
    # 按行随机打乱后划分比例
    lines = text.splitlines()
    random.shuffle(lines)
    split = int(len(lines) * (1 - args.val_ratio))
    train_text = "\n".join(lines[:split])   # 前 95% 作为训练集
    val_text   = "\n".join(lines[split:])   # 后 5% 作为验证集
    
    # 创建数据集对象
    train_ds = CharDataset(train_text, char2idx, args.seq_len)
    val_ds   = CharDataset(val_text,   char2idx, args.seq_len)
    
    # 创建数据加载器（批处理、 shuffle）
    train_loader = DataLoader(train_ds, batch_size=args.batch_size, 
                             shuffle=True, drop_last=True)
    val_loader   = DataLoader(val_ds,   batch_size=args.batch_size, 
                             shuffle=True, drop_last=True)
    
    # ── 5. 创建模型 ──
    model = LM(
        vocab_size=vocab_size,
        embed_dim=args.embed_dim,
        hidden_dim=args.hidden_dim,
        num_layers=args.num_layers,
        model_type=args.model,
        dropout=args.dropout,
        nhead=args.nhead,
    ).to(device)  # 迁移模型到指定设备
    
    # 打印模型参数量
    total_params = sum(p.numel() for p in model.parameters())
    print(f"模型参数量: {total_params:,}")
    
    # ── 6. 设置优化器和损失函数 ──
    criterion = nn.CrossEntropyLoss()  # 交叉熵损失（分类任务标准损失）
    optimizer = torch.optim.Adam(model.parameters(), lr=args.lr)
    
    # ── 7. 训练循环 ──
    best_val_ppl = float("inf")  # 记录最佳验证困惑度
    
    # 打印表头
    print(f"\n{'Epoch':>6}  {'Train Loss':>10}  {'Train PPL':>10}  {'Val Loss':>10}  {'Val PPL':>10}")
    print("-" * 56)
    
    for epoch in range(1, args.epochs + 1):
        # 训练一个 epoch
        tr_loss, tr_ppl = run_epoch(model, train_loader, criterion, 
                                     optimizer, device, train=True)
        # 验证（不更新参数）
        with torch.no_grad():
            va_loss, va_ppl = run_epoch(model, val_loader, criterion, 
                                         optimizer, device, train=False)
        
        # 标记最佳模型
        marker = "  *" if va_ppl < best_val_ppl else ""
        if va_ppl < best_val_ppl:
            best_val_ppl = va_ppl
            # 保存最佳模型及其相关配置
            torch.save({
                "model_state": model.state_dict(),  # 模型参数
                "char2idx": char2idx,               # 字符映射表（推理时需要）
                "idx2char": idx2char,
                "args": vars(args),                 # 训练超参数
            }, args.save)
        
        # 打印当前 epoch 结果
        print(f"{epoch:>6}  {tr_loss:>10.4f}  {tr_ppl:>10.2f}  {va_loss:>10.4f}  {va_ppl:>10.2f}{marker}")
    
    print(f"\n训练完成。最佳验证 PPL: {best_val_ppl:.2f}  已保存至 {args.save}")
    
    # ── 8. 文本生成演示 ──
    print("\n" + "=" * 50)
    print("文本生成演示")
    print("=" * 50)
    
    prompts = ["今天天气", "我爱"]
    for prompt in prompts:
        generated = generate(model, idx2char, char2idx, prompt, args.seq_len)
        print(f"提示: {prompt}")
        print(f"生成: {generated}")
        print("-" * 50)


if __name__ == "__main__":
    main()
