#                         数据处理部分
# ═══════════════════════════════════════════════════════════════

def load_corpus(pattern="*.txt"):
    """
    从指定路径加载语料库文件。
    
    Args:
        pattern: 文件匹配模式，默认为 "*.txt"，匹配当前目录下所有 txt 文件
    
    Returns:
        将所有文件内容拼接成的单一字符串
    
    工作流程:
        1. glob.glob(pattern) 查找所有匹配的文件路径
        2. 逐个读取文件内容（忽略编码错误）
        3. 用空字符串拼接所有内容
    """
    texts = []
    # glob.glob 返回匹配模式的所有文件路径列表
    for path in glob.glob(pattern):
        # 以 UTF-8 编码打开文件，忽略无法解码的字符
        with open(path, encoding="utf-8", errors="ignore") as f:
            texts.append(f.read())
    # 将所有文本片段拼接成一个完整字符串
    return "".join(texts)


def build_vocab(text):
    """
    根据语料库构建字符到索引的映射表。
    
    Args:
        text: 输入的完整语料文本
    
    Returns:
        char2idx: 字符 → 索引 的字典，例如 {'a': 0, 'b': 1, ...}
        idx2char: 索引 → 字符 的字典，例如 {0: 'a', 1: 'b', ...}
    
    构建步骤:
        1. set(text) 找出文本中所有不重复的字符
        2. sorted(...) 对字符排序，保证词表顺序固定（可复现）
        3. 建立双向映射字典
    """
    # 找出所有唯一字符并排序（排序保证结果可复现）
    chars = sorted(set(text))
    # 字符 → 索引，例如 {'中': 0, '国': 1, '人': 2, ...}
    char2idx = {c: i for i, c in enumerate(chars)}
    # 索引 → 字符，反向映射
    idx2char = {i: c for c, i in char2idx.items()}
    return char2idx, idx2char


class CharDataset(Dataset):
    """
    字符级语言模型数据集类。
    
    核心思想:
        给定长度为 seq_len 的字符序列 x，预测下一个字符 y
        例如: seq_len=5, text="hello"
              x = [h, e, l, l, o]  →  y = [e, l, l, o, ?]
    
    数据采样方式:
        滑动窗口，步长为 1
        "hello" (seq_len=2) 生成:
            (h,e)→l, (e,l)→l, (l,l)→o
    """
    
    def __init__(self, text, char2idx, seq_len):
        """
        初始化数据集。
        
        Args:
            text: 文本内容（字符串）
            char2idx: 字符到索引的映射字典
            seq_len: 输入序列长度（每个样本包含的字符数）
        """
        self.seq_len = seq_len
        # 将文本中的每个字符转换为对应的索引，生成一维张量
        # 例如: "hello" → [104, 101, 108, 108, 111] (ASCII码)
        ids = [char2idx[c] for c in text if c in char2idx]
        self.data = torch.tensor(ids, dtype=torch.long)
    
    def __len__(self):
        """
        返回数据集的样本数量。
        
        公式: len(text) - seq_len
        原因: 最后一个字符没有"下一个字符"，不能作为样本
        
        例如: text="hello"(5字符), seq_len=2
              有效样本: he, el, ll, lo (4个)
              5 - 2 = 3，但实际需要 4 个样本？
              实际上是: he→e, el→l, ll→l, lo→o
              数量 = len(data) - seq_len = 5 - 2 + 1 = 4
        """
        return max(0, len(self.data) - self.seq_len)
    
    def __getitem__(self, idx):
        """
        获取单个训练样本。
        
        Args:
            idx: 样本索引 [0, len(self)-1]
        
        Returns:
            x: 输入序列，形状 (seq_len,)
            y: 目标序列，形状 (seq_len,)
        
        示例:
            text="hello", seq_len=2
            idx=0: x=[h,e], y=[e,l]
            idx=1: x=[e,l], y=[l,l]
            idx=2: x=[l,l], y=[l,o]
            idx=3: x=[l,o], y=[o,?] (最后一个字符的下一个字符不存在)
        """
        x = self.data[idx: idx + self.seq_len]
        # y 是 x 向右平移一位的结果（预测下一个字符）
        y = self.data[idx + 1: idx + self.seq_len + 1]
        return x, y


