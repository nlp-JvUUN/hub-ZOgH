def run_epoch(model, loader, criterion, optimizer, device, train=True):
    """
    执行一个训练或评估轮次。
    
    Args:
        model: 语言模型
        loader: 数据加载器
        criterion: 损失函数（CrossEntropyLoss）
        optimizer: 优化器（训练时使用，评估时为 None）
        device: 计算设备（cuda 或 cpu）
        train: True=训练模式，False=评估模式
    
    Returns:
        avg_loss: 平均损失（负对数似然的均值）
        ppl: 困惑度 (Perplexity)
    
    困惑度 (PPL) 解释:
        PPL = exp(loss)
        物理意义：模型预测下一个字符时的"平均选择困惑度"
        - PPL = 词表大小 → 随机猜测（最差）
        - PPL = 1 → 完全准确（理想，但不可能）
        - PPL 越低越好
    """
    # 设置模型模式：train() 或 eval()
    model.train(train)
    total_loss = 0.0
    total_tokens = 0  # 统计处理的字符总数
    
    for x, y in loader:
        # 将数据迁移到指定设备
        x, y = x.to(device), y.to(device)
        
        # 前向传播
        logits = model(x)
        
        # 计算损失
        # logits: (B, T, V) → reshape: (B*T, V)
        # y: (B, T) → reshape: (B*T,)
        loss = criterion(logits.reshape(-1, logits.size(-1)), y.reshape(-1))
        
        if train:
            # 训练时：反向传播 + 参数更新
            optimizer.zero_grad()  # 清除上一步的梯度
            loss.backward()         # 计算当前梯度
            optimizer.step()       # 更新参数
        
        # 累计损失（乘以 token 数，因为每个样本有多个 token）
        total_loss += loss.item() * y.numel()
        total_tokens += y.numel()
    
    # 计算平均损失和困惑度
    avg_loss = total_loss / total_tokens
    ppl = math.exp(avg_loss)
    return avg_loss, ppl


