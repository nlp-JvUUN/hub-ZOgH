class PositionalEncoding(nn.Module):
    """
    位置编码层，为输入序列中的每个位置添加独特的位置信号。
    
    为什么需要位置编码？
        Transformer 的自注意力机制是"位置无关"的——它把输入序列看作
        一个集合，不区分元素的先后顺序。例如 "我爱你" 和 "你爱我" 在
        不加位置信息的情况下会产生相同的表示。
    
    位置编码的原理：
        使用正弦和余弦函数的不同频率来编码位置信息：
            PE(pos, 2i)   = sin(pos / 10000^(2i/d_model))
            PE(pos, 2i+1) = cos(pos / 10000^(2i/d_model))
        
        其中 pos 是位置，i 是维度索引，d_model 是嵌入维度。
    
    位置编码的优点：
        1. 可以处理任意长度的序列（不超过 max_len）
        2. 相对位置关系可以通过线性变换得到（因为 sin(a+b) 和 cos(a+b)
           可以表达 a 和 b 的差值）
        3. 无需学习，固定不变，节省参数
    
    Args:
        d_model: 嵌入维度（必须与输入特征维度一致）
        max_len: 支持的最大序列长度
        dropout: Dropout 概率，防止过拟合
    """
    
    def __init__(self, d_model, max_len=5000, dropout=0.1):
        super().__init__()
        self.dropout = nn.Dropout(p=dropout)
        
        # 创建位置编码矩阵，形状为 (max_len, d_model)
        # 每一行代表一个位置，每一列代表一个编码维度
        pe = torch.zeros(max_len, d_model)
        
        # position: (max_len, 1) 形状，表示每个位置的索引
        position = torch.arange(0, max_len, dtype=torch.float).unsqueeze(1)
        
        # div_term: 控制不同维度的频率
        # 使用 exp(-log(10000^(2i/d))) = 10000^(-2i/d)
        # 使得不同维度使用不同的频率周期
        div_term = torch.exp(
            torch.arange(0, d_model, 2, dtype=torch.float) 
            * (-math.log(10000.0) / d_model)
        )
        
        # 偶数维度 (0, 2, 4, ...) 使用 sin 函数
        pe[:, 0::2] = torch.sin(position * div_term)
        # 奇数维度 (1, 3, 5, ...) 使用 cos 函数
        pe[:, 1::2] = torch.cos(position * div_term)
        
        # 添加批次维度: (1, max_len, d_model)
        pe = pe.unsqueeze(0)
        
        # register_buffer 的作用：
        # 1. 将 pe 注册为模型的一部分
        # 2. 但不会被视为需要梯度更新的参数
        # 3. 会在模型保存/加载时一起保存/加载
        self.register_buffer('pe', pe)
    
    def forward(self, x):
        """
        前向传播，将位置编码添加到输入上。
        
        Args:
            x: 输入张量，形状 (batch_size, seq_len, d_model)
        
        Returns:
            添加位置编码后的张量，形状不变
        """
        # 切片 [:, :x.size(1), :] 确保支持可变长度的序列
        # 如果输入序列短于 max_len，只使用对应位置的编码
        x = x + self.pe[:, :x.size(1), :]
        return self.dropout(x)

class LM(nn.Module):
    """
    语言模型核心网络，支持三种架构：RNN、LSTM、Transformer。
    
    架构选择逻辑：
        - model_type == "rnn": 使用基础的循环神经网络
        - model_type == "lstm": 使用长短期记忆网络（有记忆单元）
        - model_type == "transformer": 使用 Transformer 编码器
    
    网络结构（以 Transformer 为例，自底向上）:
        ┌─────────────────────────────────────────────────────┐
        │  Input (字符索引)                                     │
        │  形状: (batch_size, seq_len)                         │
        └─────────────────────┬───────────────────────────────┘
                              ↓
        ┌─────────────────────────────────────────────────────┐
        │  Embedding Layer                                    │
        │  vocab_size → embed_dim                             │
        │  形状: (batch_size, seq_len, embed_dim)             │
        └─────────────────────┬───────────────────────────────┘
                              ↓
        ┌─────────────────────────────────────────────────────┐
        │  Positional Encoding                                │
        │  添加位置信息，使模型能感知序列顺序                   │
        └─────────────────────┬───────────────────────────────┘
                              ↓
        ┌─────────────────────────────────────────────────────┐
        │  Transformer Encoder / RNN / LSTM                  │
        │  捕获序列中的长距离依赖关系                          │
        └─────────────────────┬───────────────────────────────┘
                              ↓
        ┌─────────────────────────────────────────────────────┐
        │  Linear Layer                                      │
        │  embed_dim → vocab_size                            │
        │  输出每个位置对词表中每个字符的"得分"                │
        └─────────────────────┬───────────────────────────────┘
                              ↓
        ┌─────────────────────────────────────────────────────┐
        │  Output (每个字符作为下一个字符的概率分数)           │
        │  形状: (batch_size, seq_len, vocab_size)           │
        └─────────────────────────────────────────────────────┘
    
    Transformer 的特殊处理：
        1. 位置编码：通过 PositionalEncoding 添加位置信息
        2. 因果掩码：通过 generate_causal_mask 确保单向性
           （只能看到当前位置及之前的 token）
    
    前向传播:
        输入:  (batch_size, seq_len) 的字符索引
        输出: (batch_size, seq_len, vocab_size) 的概率分布分数
    """
    
    def __init__(self, vocab_size, embed_dim, hidden_dim, num_layers, model_type, dropout, nhead=8):
        """
        初始化语言模型。
        
        Args:
            vocab_size: 词表大小（不同字符的数量）
            embed_dim: 字符嵌入维度（每个字符表示成多维向量）
            hidden_dim: 前馈网络维度（Transformer）/ 隐藏层维度（RNN/LSTM）
            num_layers: 层数（多层堆叠增强表达能力）
            model_type: "rnn", "lstm" 或 "transformer"
            dropout: Dropout 比例（防止过拟合）
            nhead: Transformer 注意力头数
        """
        super().__init__()
        self.model_type = model_type
        
        # ── 嵌入层 ──
        self.embed = nn.Embedding(vocab_size, embed_dim)
        self.pos_encoder = PositionalEncoding(embed_dim, dropout=dropout)
        
        if model_type == "transformer":
            # Transformer Encoder
            encoder_layer = nn.TransformerEncoderLayer(
                d_model=embed_dim,
                nhead=nhead,
                dim_feedforward=hidden_dim,
                dropout=dropout,
                batch_first=True
            )
            self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)
            self.fc = nn.Linear(embed_dim, vocab_size)
        else:
            # RNN/LSTM
            rnn_cls = nn.LSTM if model_type == "lstm" else nn.RNN
            self.rnn = rnn_cls(
                embed_dim,
                hidden_dim,
                num_layers=num_layers,
                batch_first=True,
                dropout=dropout if num_layers > 1 else 0.0,
            )
            self.fc = nn.Linear(hidden_dim, vocab_size)
    
    def forward(self, x):
        """
        前向传播。
        
        Args:
            x: 输入张量，形状 (batch_size, seq_len)
        
        Returns:
            logits: 预测的分数（未归一化），形状 (batch_size, seq_len, vocab_size)
        """
        # 字符索引转为嵌入向量
        e = self.embed(x)
        
        if self.model_type == "transformer":
            # 添加位置编码
            e = e * math.sqrt(self.embed.embedding_dim)
            e = self.pos_encoder(e)
            
            # 生成因果掩码
            seq_len = x.size(1)
            tgt_mask = generate_causal_mask(seq_len, x.device)
            
            # Transformer 处理
            out = self.transformer(e, mask=tgt_mask)
        else:
            # RNN/LSTM 处理
            out, _ = self.rnn(e)
        
        return self.fc(out)


def generate_causal_mask(seq_len, device):
    """
    生成因果掩码，确保当前位置只能看到当前位置及之前的 token。
    
    Args:
        seq_len: 序列长度
        device: 计算设备
    
    Returns:
        mask: (seq_len, seq_len) 的布尔张量
               True 表示需要掩盖的位置（未来 token）
    """
    mask = torch.triu(
        torch.ones(seq_len, seq_len, device=device, dtype=torch.bool), 
        diagonal=1
    )
    return mask


def generate(model, idx2char, char2idx, prompt, seq_len, max_new_tokens=100, temperature=1.0):
    """
    基于给定提示文本生成后续内容。
    
    Args:
        model: 训练好的语言模型
        idx2char: 索引到字符的映射
        char2idx: 字符到索引的映射
        prompt: 起始提示文本
        seq_len: 模型训练的序列长度
        max_new_tokens: 最大生成字符数
        temperature: 采样温度（越高越随机）
    
    Returns:
        生成的完整文本（包括原始提示）
    """
    model.eval()
    input_ids = [char2idx[c] for c in prompt if c in char2idx]
    
    for _ in range(max_new_tokens):
        # 截断到 seq_len
        input_tensor = torch.tensor([input_ids[-seq_len:]], dtype=torch.long)
        with torch.no_grad():
            logits = model(input_tensor)
        
        # 取最后一个位置的预测
        next_token_logits = logits[0, -1, :] / temperature
        probs = torch.softmax(next_token_logits, dim=-1)
        next_token = torch.multinomial(probs, num_samples=1).item()
        
        if next_token == char2idx.get('\n', -1):
            break
        input_ids.append(next_token)
    
    return ''.join([idx2char[i] for i in input_ids])


